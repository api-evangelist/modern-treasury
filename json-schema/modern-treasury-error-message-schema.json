{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/error_message",
  "title": "error_message",
  "type": "object",
  "properties": {
    "errors": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "parameter_invalid",
            "parameter_missing",
            "resource_not_found",
            "not_found",
            "forbidden",
            "invalid_ip",
            "invalid_key",
            "header_invalid",
            "expired_key",
            "conflict",
            "too_many_requests"
          ]
        },
        "message": {
          "type": "string"
        },
        "parameter": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "errors"
  ]
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/balance_report_create_request",
  "title": "balance_report_create_request",
  "type": "object",
  "properties": {
    "as_of_date": {
      "type": "string",
      "format": "date",
      "description": "The date of the balance report in local time."
    },
    "as_of_time": {
      "type": "string",
      "description": "The time (24-hour clock) of the balance report in local time."
    },
    "balance_report_type": {
      "type": "string",
      "enum": [
        "intraday",
        "other",
        "previous_day",
        "real_time"
      ],
      "description": "The specific type of balance report. One of `intraday`, `previous_day`, `real_time`, or `other`."
    },
    "balances": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/balance_create_request"
      },
      "description": "An array of `Balance` objects."
    }
  },
  "required": [
    "as_of_date",
    "as_of_time",
    "balance_report_type",
    "balances"
  ]
}